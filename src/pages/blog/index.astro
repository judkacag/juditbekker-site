---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
  });
}
---
<Layout title="Blog – Judit Bekker" description="Writing about data visualization, Tableau, and other things Judit cares about.">

  <section class="blog-page">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`${base}blog/${post.id}`} class="post-card">
            {post.data.heroImage && (
              <div class="post-card-image">
                <img src={`${base}${post.data.heroImage}`} alt="" loading="lazy" />
              </div>
            )}
            <div class="post-card-body">
              <div class="post-meta">
                <span class="post-date">{formatDate(post.data.date)}</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .blog-page {
    padding: 56px 0 80px;
  }

  /* fallback before JS runs */
  .blog-grid {
    columns: 3;
    column-gap: 24px;
  }

  /* JS-driven masonry resets the columns layout */
  .blog-grid.js-masonry {
    columns: unset;
    position: relative;
  }

  .post-card {
    display: block;
    break-inside: avoid;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 24px;
    margin-bottom: 32px;
    transition: opacity 0.2s;
  }

  .blog-grid.js-masonry .post-card {
    position: absolute;
    margin-bottom: 0;
  }

  .post-card:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .post-card-image {
    margin-bottom: 16px;
  }

  .post-card-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-card-body {
    padding-top: 4px;
  }

  .post-meta {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 8px;
    letter-spacing: 0.03em;
  }

  .post-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .post-excerpt {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .blog-grid { columns: 2; }
  }

  @media (max-width: 600px) {
    .blog-grid { columns: 1; }
  }
</style>

<script is:inline>
  (function () {
    const GAP_X = 24;
    const GAP_Y = 32;

    function numCols() {
      const w = window.innerWidth;
      if (w > 900) return 3;
      if (w > 600) return 2;
      return 1;
    }

    function layout() {
      const grid = document.querySelector('.blog-grid');
      if (!grid) return;
      const cols = numCols();

      if (cols === 1) {
        // revert to normal flow on mobile
        grid.classList.remove('js-masonry');
        grid.style.height = '';
        Array.from(grid.querySelectorAll('.post-card')).forEach(function (card) {
          card.style.width = '';
          card.style.left = '';
          card.style.top = '';
        });
        return;
      }

      const cards = Array.from(grid.querySelectorAll('.post-card'));
      const gridW = grid.clientWidth;
      const colW = (gridW - GAP_X * (cols - 1)) / cols;
      const heights = new Array(cols).fill(0);

      // set widths first so offsetHeight is correct
      cards.forEach(function (card) {
        card.style.width = colW + 'px';
      });

      grid.classList.add('js-masonry');

      // place items left-to-right: item i goes into column i % cols
      cards.forEach(function (card, i) {
        const col = i % cols;
        card.style.left = col * (colW + GAP_X) + 'px';
        card.style.top = heights[col] + 'px';
        heights[col] += card.offsetHeight + GAP_Y;
      });

      grid.style.height = Math.max.apply(null, heights) + 'px';
    }

    window.addEventListener('load', layout);
    window.addEventListener('resize', layout);
    document.addEventListener('DOMContentLoaded', layout);
  })();
</script>
