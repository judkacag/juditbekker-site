---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Judit Bekker – Portfolio">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-left">
        <div class="hero-photo-wrap">
          <img src={`${import.meta.env.BASE_URL}images/judit-portrait.jpg`} alt="Judit Bekker" class="hero-photo" />
        </div>
        <div class="hero-meta">
          <strong class="hero-name">Judit Bekker</strong>
          <span>Data Visualization Designer</span>
          <span>2x Tableau Zen Master</span>
          <span>Berlin, Germany</span>
        </div>
        <div class="social-links">
