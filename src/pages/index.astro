---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const portfolioItems = [
  {
    key: 'twin-peaks',
    title: 'The Coffees of Twin Peaks',
    image: 'twin-peaks.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/TheCoffeesofTwinPeaks/TheCoffeesofTwinPeaks',
    description: 'Welcome to The Coffees of Twin Peaks! This fun visualization project showcases the 258 cups of coffee that were consumed throughout the Twin Peaks series. It took an insane amount of time to count them all, given that the show is approximately 40 hours long. So grab a cup of joe and explore the coffee-filled world of Twin Peaks!',
  },
  {
    key: 'beer-hiking',
    title: 'Beer Hiking in Berlin',
    image: 'beer-hiking.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/BeerhikinginBerlin/bierwandern',
    description: 'Introducing Beer Hiking in Berlin, a complex dataviz project that highlights 33 unique hiking routes around the city, all of which conclude at a local brewery. These routes, inspired by the book of the same name, cater to hikers of all experience levels and time constraints, offering a diverse range of options for locals and tourists alike.',
  },
  {
    key: 'composers',
    title: 'Most Famous Composers of the 20th Century',
    image: 'composers.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/Mostfamouscomposersofthe20thcentury/Composersofthe20thcentury',
    description: 'During the early 20th century, many composers experimented with rhythm, gained inspiration from folk music and assessed their views on tonality. These experimentations baffled listeners, and composers either received support or were rejected by their audience. This resulted in a shift in how music was composed and performed.',
  },
  {
    key: 'what-s-in-the-bag',
    title: "What's in the Bag?",
    image: 'what-s-in-the-bag.png',
    link: 'https://www.behance.net/gallery/115499067/Whats-in-the-bag',
    description: 'The share of income spent on groceries is an established indicator of household food security. In 2019 in Hungary the ratio of food and non-alcoholic beverages took up a quarter of all earnings, while the EU average was below 15%. Explore this experimental infographic to see what an average Hungarian spends their income on.',
  },
  {
    key: 'wild-at-heart',
    title: 'Wild at Heart',
    image: 'wild-at-heart.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/WildatHeart/WildatHeart',
    description: 'Wild at Heart is a data visualization piece that explores the film of the same name by David Lynch. I counted the number of cigarettes smoked, instances of lovemaking, and singing by the main characters throughout the film. The viz was recreated three times in different tools: Tableau, Adobe Illustrator, and p5.js.',
  },
  {
    key: 'kodak',
    title: 'The History of Modern Photography',
    image: 'kodak.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/Thehistoryofmodernphotography/Historyofmodernphotography',
    description: 'Small visuals, a lot of everything else. This work has only two charts on the canvas, and everything else is centered around layout design. I saved this photo from Alexander Andrews to my favourites on Pexels months ago before I found the most suitable font to tell a story.',
  },
  {
    key: 'fire-walk-with-me',
    title: 'Fire Walk With Me',
    image: 'fire-walk-with-me.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/setmymindonFIRE/Firewalkwithme',
    description: 'In 2020 I watched 645 hours of movies and series. Yes, that equals 27 days and it\'s almost as long as February. 73% of this time I spent watching series – 660 episodes of 62 different ones. My main platform was Netflix (270 hours), closely followed by HBO GO (250 hours), while I only went to the movies 3 times due to the lockdown.',
  },
  {
    key: 'lakes-of-berlin',
    title: 'Largest Lakes around Berlin',
    image: 'lakes-of-berlin.png',
    link: 'https://www.behance.net/gallery/169433427/Largest-lakes-around-Berlin',
    description: 'The Lakes of Berlin project is a static visualization that showcases the largest lakes around Berlin. This infographic allows viewers to see the size, depth, and location of each lake compared to the city center. A lot of lines were drawn to complete this viz, but it was a fun and relaxing activity!',
  },
  {
    key: 'amy-adams',
    title: 'Amy Adams Career',
    image: 'amy-adams.png',
    link: 'https://www.behance.net/gallery/122698727/Amy-Adams-movies',
    description: 'This dataviz project showcases an in-depth infographic detailing the career of Amy Adams from 2006 to 2019. Created using Adobe Illustrator, the project used data from IMDb and Rotten Tomatoes.',
  },
  {
    key: 'severance',
    title: 'Please Enjoy Each Fact Equally',
    image: 'severance.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/SeverancePleaseenjoyeachfactequally/Ahandshakeisavailableuponrequest',
    description: 'I hope Mr. Milchick will organize an Egg Bar Social, and a handshake will be available upon request after completing the Severance file. Macrodata Refinement has reached quota by the end of the quarter, and that gantt chart did bend after all!',
  },
  {
    key: 'iceland',
    title: 'The Land of Ice and Fire',
    image: 'iceland.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/IcelandTheLandofFireandIce/IcelandThelandoffireandice',
    description: 'Iceland has a unique landscape with its completely unmatched rugged nature. On an island only 103,000 km² in size, there is a large number of volcanoes, glaciers, black sand beaches, waterfalls, and craters — making it a nature lover\'s paradise. In this viz I chose to visualize all the active volcanoes of Iceland in Mapbox Studio.',
  },
  {
    key: 'moon-phases',
    title: 'Moon Phases 2020',
    image: 'moon-phases.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/moonpalace/Moonphases2020',
    description: 'The 2020 Lunar calendar project was a rapid visualization idea when I was in-between projects and had some idle time on my hands. This is a very simple viz about the changing phases of the Moon that still stands close to my heart.',
  },
  {
    key: 'eastern-bloc',
    title: 'Eastern Bloc',
    image: 'eastern-bloc.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/EasternBloc-StalinistArchitecture/Eastern_bloc',
    description: 'This was one of those many design-driven vizzes where I knew how the end result should look like, just needed to find the data that fits my story. I grew up in one of these panel houses in Hungary, and wouldn\'t trade those years for anything.',
  },
  {
    key: 'infinite-jest',
    title: 'Infinite Jest',
    image: 'infinite-jest.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/infinite_jest/InfiniteJest',
    description: 'Infinite Jest is the thickest and most complicated reads of my life so far — 1100 pages in a very big format written in 8pt font size. But hey, I like literary challenges! This viz was a true love project.',
  },
  {
    key: 'woody-allen',
    title: "Woody Allen's Filmography",
    image: 'woody-allen.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/WoodyAllenTheManfromNewYork/WoodyAllen',
    description: 'He was as tough and romantic as the city he loved. Behind his black-rimmed glasses was the coiled sexual power of a jungle cat. New York was his town and it always would be. Between 1966 and 2019 Woody Allen has made a film almost every year.',
  },
  {
    key: 'my-fallen-kingdom',
    title: 'My Fallen Kingdom – A Quarantine Project',
    image: 'my-fallen-kingdom.png',
    link: 'https://public.tableau.com/app/profile/judit.bekker/viz/MyFallenKingdom/Fallenkingdom',
    description: 'I took a measuring tape and drew out the layout of my flat to make a heat-map of what I\'m doing for how long in the apartment. Why? Cause it was peak quarantine time and I had very little to do. This project came in handy for a future renovation project.',
  },
];
---
<Layout title="Judit Bekker – Portfolio">

  <!-- Search bar in nav -->
  <div slot="nav-search" class="nav-search">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="search" id="portfolio-search" placeholder="Search..." autocomplete="off" />
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">

      <!-- Left: photo + meta (gradient covers whole column) -->
      <div class="hero-left">
        <img src={`${base}images/judit-portrait.jpg`} alt="Judit Bekker" class="hero-photo" />
        <div class="hero-meta">
          <strong class="hero-name">Judit Bekker</strong>
          <span class="hero-title">Data Visualization Designer</span>
          <span class="hero-detail">2x Tableau Zen Master</span>
          <span class="hero-detail">Berlin, Germany</span>
        </div>
      </div>

      <!-- Center: text + buttons -->
      <div class="hero-center">
        <h1 class="hero-greeting">HEY THERE,</h1>
        <p class="hero-bio">welcome to my website! I'm Judit Bekker, and I'm happy to have you here. I've been working as a Data Visualization Designer and Analyst for 15 years, and I'm obsessed with all things data. Whether I'm finding new ways to visualize complex information or digging into data to uncover insights, I'm always up to something. I tend to choose topics that need unique datasets, and if I'm married to an idea I don't mind spending a month working on a viz. Spoiler alert: I once counted all the damn fine coffees that were consumed in Twin Peaks, and those 50 hours flew by faster than a coffee gets cold.</p>
        <p class="hero-bio">When I'm not working, you can catch me doodling on photos, coming up with new hobbies, or running away from my arch enemies: pigeons. I'm excited to share my projects and knowledge with you on this new website where I can finally embrace my everlasting love for my favourite font: Futura!</p>
        <div class="hero-ctas">
          <a href={`${base}about-me`} class="btn-link">More About Me</a>
          <a href="#portfolio" class="btn-link">My Portfolio</a>
        </div>
      </div>

      <!-- Right: vertical social icons -->
      <div class="hero-social">
        <a href="https://www.linkedin.com/in/bekkerjudit/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <img src={`${base}images/icons/linkedin.png`} alt="LinkedIn" />
        </a>
        <a href="https://public.tableau.com/app/profile/judit.bekker/vizzes" target="_blank" rel="noopener" aria-label="Tableau Public">
          <img src={`${base}images/icons/tableau.png`} alt="Tableau" />
        </a>
        <a href="https://www.behance.net/bekkerjudk90a4" target="_blank" rel="noopener" aria-label="Behance">
          <img src={`${base}images/icons/behance.png`} alt="Behance" />
        </a>
        <a href="https://hu.pinterest.com/judkacag/" target="_blank" rel="noopener" aria-label="Pinterest">
          <img src={`${base}images/icons/pinterest.png`} alt="Pinterest" />
        </a>
        <a href="https://github.com/judkacag" target="_blank" rel="noopener" aria-label="GitHub">
          <img src={`${base}images/icons/github.png`} alt="GitHub" />
        </a>
      </div>

    </div>
  </section>

  <!-- Portfolio -->
  <section class="portfolio" id="portfolio">
    <div class="container">
      <h2 class="section-title">My Portfolio</h2>
      <p class="section-subtitle">Here you'll find a selection of my work, and soon realise that the majority of them are about movies and television. Click on the images to get to know more, and explore the interactive versions.</p>
      <div class="portfolio-grid" id="portfolio-grid">
        {portfolioItems.map(item => (
          <a
            href={item.link}
            target="_blank"
            rel="noopener"
            class="portfolio-item"
            data-title={item.title.toLowerCase()}
          >
            <img
              src={`${base}images/portfolio/${item.image}`}
              alt={item.title}
              loading="lazy"
            />
            <div class="portfolio-overlay">
              <h3 class="overlay-title">{item.title}</h3>
              <p class="overlay-desc">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="no-results" id="no-results" style="display:none">No results found.</p>
    </div>
  </section>

</Layout>

<script>
  const searchInput = document.getElementById('portfolio-search') as HTMLInputElement | null;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase();
      let visible = 0;
      document.querySelectorAll<HTMLElement>('.portfolio-item').forEach(item => {
        const match = (item.dataset.title || '').includes(q);
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      const noResults = document.getElementById('no-results');
      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    });
  }
</script>

<style>
  /* ── Nav search ──────────────────────────────────────────────── */
  .nav-search {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-border);
    padding: 5px 12px;
    color: var(--color-muted);
  }

  .nav-search input {
    border: none;
    outline: none;
    font-family: var(--font-main);
    font-size: 1rem;
    color: var(--color-text);
    background: transparent;
    width: 160px;
  }

  .nav-search input::placeholder {
    color: var(--color-muted);
  }

  /* ── Hero ────────────────────────────────────────────────────── */
  .hero {
    padding: 56px 0 72px;
  }

  .hero-inner {
    display: flex;
    gap: 56px;
    align-items: flex-start;
  }

  /* Left column: gradient covers whole box */
  .hero-left {
    flex: 0 0 300px;
    background: linear-gradient(180deg, rgba(250,212,189,0.75) 0%, #ffffff 100%);
    padding: 28px 20px 32px;
    display: flex;
    flex-direction: column;
    animation: slideLeft 0.65s ease both;
  }

  .hero-photo {
    width: 100%;
    display: block;
    margin-bottom: 20px;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: #363636;
    padding-left: 24px;
  }

  .hero-name {
    font-size: 30px;
    font-weight: 700;
    line-height: 1.2;
  }

  .hero-title {
    font-size: 19px;
    font-weight: 400;
  }

  .hero-detail {
    font-size: 17px;
    font-weight: 400;
  }

  /* blank-line gap between title and the first detail */
  .hero-title + .hero-detail {
    margin-top: 1em;
  }

  /* Center column: greeting + bio + buttons */
  .hero-center {
    flex: 0 1 520px;
    min-width: 0;
    padding-top: 4px;
    animation: slideRight 0.65s ease 0.1s both;
  }

  .hero-greeting {
    font-family: Impact, 'Arial Narrow', sans-serif;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 400;
    color: #DC9C79;
    letter-spacing: 0.01em;
    line-height: 1;
    margin-bottom: 28px;
  }

  .hero-bio {
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 16px;
    color: var(--color-text);
    text-align: justify;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .btn-link {
    display: inline-block;
    padding: 10px 28px;
    background: transparent;
    color: #363636;
    font-family: var(--font-main);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid #cccccc;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .btn-link:hover {
    background: #F28080;
    color: #ffffff;
    border-color: #F28080;
    text-decoration: none;
  }

  /* Right column: social icons */
  .hero-social {
    flex: 0 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    /* start at the same vertical position as the bio text */
    padding-top: calc(clamp(3rem, 5.5vw, 5.5rem) + 28px);
    animation: slideRight 0.65s ease 0.15s both;
  }

  .hero-social a {
    display: block;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .hero-social a:hover {
    opacity: 1;
    text-decoration: none;
  }

  .hero-social img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: block;
  }

  /* ── Animations ──────────────────────────────────────────────── */
  @keyframes slideLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes slideRight {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Portfolio ───────────────────────────────────────────────── */
  .portfolio {
    padding: 64px 0 80px;
    border-top: 1px solid var(--color-border);
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
    text-align: center;
  }

  .section-subtitle {
    color: var(--color-muted);
    font-size: 0.9rem;
    max-width: 600px;
    margin: 0 auto 40px;
    text-align: center;
    line-height: 1.7;
  }

  .portfolio-grid {
    columns: 3;
    column-gap: 20px;
  }

  .portfolio-item {
    break-inside: avoid;
    display: block;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .portfolio-item img {
    width: 100%;
    display: block;
    border: 1px solid var(--color-border);
    transition: transform 0.35s ease;
  }

  .portfolio-item:hover img {
    transform: scale(1.03);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(250,212,189,0.95) 0%, rgba(255,255,255,0.97) 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 28px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .portfolio-item:hover .portfolio-overlay {
    opacity: 1;
  }

  .overlay-title {
    color: #363636;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .overlay-desc {
    color: #363636;
    font-size: 0.78rem;
    line-height: 1.65;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
  }

  .no-results {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-top: 24px;
    text-align: center;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .portfolio-grid { columns: 2; }
    .hero-inner { gap: 36px; }
    .hero-left { flex: 0 0 240px; }
  }

  @media (max-width: 680px) {
    .hero-inner {
      flex-direction: column;
      gap: 32px;
    }
    .hero-left { flex: none; width: 100%; max-width: 320px; }
    .hero-social {
      flex-direction: row;
      flex: none;
      gap: 20px;
    }
    .portfolio-grid { columns: 1; }
  }
</style>
